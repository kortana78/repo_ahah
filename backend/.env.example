APP_NAME=NyasaSport Repo API
APP_ENV=production
FRONTEND_ORIGIN=https://repo-ahah.vercel.app
FRONTEND_ORIGINS=https://repo-ahah.vercel.app,https://your-preview.vercel.app
DATABASE_URL=postgresql://user:password@host:5432/database
INIT_DB_ON_STARTUP=true
SECRET_KEY=replace-this-with-a-long-random-secret
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=1440
OPENROUTER_API_KEY=your-openrouter-api-key
OPENROUTER_MODEL=google/gemini-2.0-flash-lite-preview-02-05:free
OPENROUTER_VISION_MODEL=openai/gpt-4o-mini
OPENROUTER_VISION_FALLBACK_MODELS=google/gemini-2.0-flash-001,google/gemini-2.0-flash-lite-001
